{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowJs": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noEmitOnError": false
  },
  "include": [
    "src/server.ts",
    "src/config/**/*",
    "src/models/**/*",
    "src/routes/**/*",
    "src/middleware/**/*",
    "src/utils/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/pages/**/*",
    "src/App.tsx",
    "src/main.tsx",
    "src/**/*.test.ts",
    "**/*.tsx",
    "src/services/api.ts"
  ]
}