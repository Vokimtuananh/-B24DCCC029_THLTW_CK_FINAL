# Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to git!

# ===== MONGODB ATLAS =====
# Replace with your MongoDB connection string from Atlas
MONGODB_URI=mongodb+srv://admission_api:your_password_here@cluster0.xxxxx.mongodb.net/admission_system?retryWrites=true&w=majority

# Alternative for local MongoDB development:
# MONGODB_URI=mongodb://localhost:27017/admission_system

# ===== SERVER CONFIGURATION =====
PORT=5000
NODE_ENV=development

# ===== JWT AUTHENTICATION =====
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=7d

# ===== BCRYPT =====
BCRYPT_ROUNDS=10

# ===== CORS CONFIGURATION =====
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ===== FILE UPLOAD (Optional) =====
# Using AWS S3 or Google Cloud Storage for documents
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=admission-documents
AWS_REGION=ap-southeast-1

# ===== EMAIL SERVICE (Optional) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ===== LOGGING =====
LOG_LEVEL=info

# ===== DATABASE BACKUPS =====
# Automated backup to another storage
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *

# ===== ANALYTICS (Optional) =====
ANALYTICS_ENABLED=true
